<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="smart_wheelchair">

  <xacro:property name="PI" value="3.14159265359"/>
  <xacro:property name="base_z" value="0.50"/>

  <xacro:property name="wh_r" value="0.15"/>
  <xacro:property name="wh_w" value="0.08"/>
  <xacro:property name="wh_y" value="0.34"/> 
  <xacro:property name="wh_z" value="-0.35"/>

  <xacro:property name="ca_r" value="0.05"/>
  <xacro:property name="ca_x" value="0.18"/>
  <xacro:property name="ca_z" value="-0.45"/> <!-- 对齐高度：底部在 -0.50 -->

  <!-- 颜色 -->
  <material name="dark_grey"><color rgba="0.20 0.20 0.22 1.0"/></material>
  <material name="light_grey"><color rgba="0.70 0.70 0.72 1.0"/></material>
  <material name="metal"><color rgba="0.50 0.50 0.54 1.0"/></material>
  <material name="black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="red"><color rgba="0.85 0.12 0.12 1.0"/></material>

  <!-- ================== base_footprint ================== -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${base_z}" rpy="0 0 0"/>
  </joint>

  <!-- ================== base_link (骨架 + 座椅一体化) ================== -->
  <link name="base_link">
    <!-- A. 底盘主框架 -->
    <visual>
      <origin xyz="0 0 -0.20" rpy="0 0 0"/>
      <geometry><box size="0.45 0.36 0.08"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.15" rpy="0 0 0"/>
      <geometry><box size="0.45 0.36 0.04"/></geometry>
    </collision>

    <!-- B. 座面填充板 -->
    <visual>
      <origin xyz="0 0 -0.11" rpy="0 0 0"/>
      <geometry><box size="0.45 0.40 0.10"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 -0.11" rpy="0 0 0"/>
      <geometry><box size="0.45 0.40 0.05"/></geometry>
    </collision>

    <!-- C. 薄座垫 -->
    <visual>
      <origin xyz="0 0 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.45 0.40 0.04"/></geometry>
      <material name="dark_grey"/>
    </visual>

    <!-- 【新增】P. 左侧主框架连接桥（填补底盘与侧板之间的横向悬空） -->
    <visual>
      <origin xyz="-0.02 0.21 -0.20" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.08"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.02 0.21 -0.15" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.04"/></geometry>
    </collision>

    <!-- 【新增】Q. 右侧主框架连接桥 -->
    <visual>
      <origin xyz="-0.02 -0.21 -0.20" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.08"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.02 -0.21 -0.15" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.04"/></geometry>
    </collision>

    <!-- 【新增】R. 左侧大轮金属驱动轴（连接侧板与大轮中心） -->
    <visual>
      <origin xyz="0 0.30 -0.35" rpy="${PI/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="0.08"/></geometry>
      <material name="metal"/>
    </visual>

    <!-- 【新增】S. 右侧大轮金属驱动轴 -->
    <visual>
      <origin xyz="0 -0.30 -0.35" rpy="${PI/2} 0 0"/>
      <geometry><cylinder radius="0.025" length="0.08"/></geometry>
      <material name="metal"/>
    </visual>

    <!-- D/E/F 靠背结构 -->
    <visual>
      <origin xyz="-0.20 0.18 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.26"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.20 0.18 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.26"/></geometry>
    </collision>

    <visual>
      <origin xyz="-0.20 -0.18 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.26"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.20 -0.18 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.26"/></geometry>
    </collision>

    <visual>
      <origin xyz="-0.20 0 0.14" rpy="0 0 0"/>
      <geometry><box size="0.03 0.38 0.03"/></geometry>
      <material name="metal"/>
    </visual>

    <!-- G/H 扶手支撑 -->
    <visual>
      <origin xyz="0.05 0.24 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.25"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.05 0.24 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.25"/></geometry>
    </collision>

    <visual>
      <origin xyz="0.05 -0.24 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.25"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.05 -0.24 -0.04" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.25"/></geometry>
    </collision>

    <!-- I/J 大轮侧板 -->
    <visual>
      <origin xyz="-0.02 0.27 -0.35" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.24"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.02 0.27 -0.30" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.10"/></geometry>
    </collision>

    <visual>
      <origin xyz="-0.02 -0.27 -0.35" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.24"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.02 -0.27 -0.30" rpy="0 0 0"/>
      <geometry><box size="0.14 0.06 0.10"/></geometry>
    </collision>

    <!-- K/L 脚踏板支撑 -->
    <visual>
      <origin xyz="0.22 0 -0.28" rpy="0 0 0"/>
      <geometry><box size="0.03 0.24 0.24"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.22 0 -0.28" rpy="0 0 0"/>
      <geometry><box size="0.03 0.24 0.24"/></geometry>
    </collision>

    <visual>
      <origin xyz="0.28 0 -0.38" rpy="0 0 0"/>
      <geometry><box size="0.10 0.04 0.02"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.28 0 -0.38" rpy="0 0 0"/>
      <geometry><box size="0.10 0.04 0.02"/></geometry>
    </collision>

    <!-- M/N 前后万向轮支架 -->
    <visual>
      <origin xyz="0.18 0 -0.345" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.21"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.18 0 -0.345" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.21"/></geometry>
    </collision>

    <visual>
      <origin xyz="-0.18 0 -0.345" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.21"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="-0.18 0 -0.345" rpy="0 0 0"/>
      <geometry><box size="0.03 0.03 0.21"/></geometry>
    </collision>

    <!-- O. 雷达立柱 -->
    <visual>
      <origin xyz="0.10 0 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.28"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0.10 0 -0.01" rpy="0 0 0"/>
      <geometry><box size="0.02 0.02 0.28"/></geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 -0.12" rpy="0 0 0"/>
      <mass value="28.0"/>
      <inertia ixx="0.55" ixy="0" ixz="0"
               iyy="0.62" iyz="0"
               izz="0.85"/>
    </inertial>
  </link>

  <!-- ================== 靠背垫 ================== -->
  <link name="backrest_link">
    <visual>
      <geometry><box size="0.06 0.42 0.30"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.06 0.42 0.30"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0"
               iyy="0.04" iyz="0"
               izz="0.02"/>
    </inertial>
  </link>

  <joint name="backrest_joint" type="fixed">
    <parent link="base_link"/>
    <child link="backrest_link"/>
    <origin xyz="-0.18 0 0.16" rpy="0 0 0"/>
  </joint>

  <!-- ================== 扶手 ================== -->
  <xacro:macro name="armrest" params="prefix reflect">
    <link name="${prefix}_armrest_link">
      <visual>
        <geometry><box size="0.28 0.05 0.05"/></geometry>
        <material name="light_grey"/>
      </visual>
      <collision>
        <geometry><box size="0.28 0.05 0.05"/></geometry>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <inertia ixx="0.008" ixy="0" ixz="0"
                 iyy="0.008" iyz="0"
                 izz="0.008"/>
      </inertial>
    </link>

    <joint name="${prefix}_armrest_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_armrest_link"/>
      <origin xyz="0.05 ${reflect*0.26} 0.11" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:armrest prefix="left"  reflect="1"/>
  <xacro:armrest prefix="right" reflect="-1"/>

  <!-- ================== 脚踏板 ================== -->
  <link name="footrest_link">
    <visual>
      <geometry><box size="0.12 0.28 0.03"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <geometry><box size="0.12 0.28 0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0" ixz="0"
               iyy="0.005" iyz="0"
               izz="0.01"/>
    </inertial>
  </link>

  <joint name="footrest_joint" type="fixed">
    <parent link="base_link"/>
    <child link="footrest_link"/>
    <origin xyz="0.28 0 -0.38" rpy="0 0 0"/>
  </joint>

  <!-- ================== 驱动轮（大后轮） ================== -->
  <xacro:macro name="wheel" params="prefix reflect">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry><cylinder radius="${wh_r}" length="${wh_w}"/></geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <geometry><cylinder radius="${wh_r}" length="${wh_w}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <mass value="2.0"/>
        <inertia ixx="0.015" ixy="0" ixz="0"
                 iyy="0.015" iyz="0"
                 izz="0.0225"/>
      </inertial>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${reflect*wh_y} ${wh_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <!-- 减小 damping 和 friction，防止轮子阻力过大导致空转 -->
      <dynamics damping="0.01" friction="0.01"/>
    </joint>
  </xacro:macro>

  <xacro:wheel prefix="left"  reflect="1"/>
  <xacro:wheel prefix="right" reflect="-1"/>

  <!-- ================== 万向轮 ================== -->
  <xacro:macro name="caster" params="prefix reflect">
    <link name="${prefix}_caster_link">
      <visual>
        <geometry><sphere radius="${ca_r}"/></geometry>
        <material name="metal"/>
      </visual>
      <collision>
        <geometry><sphere radius="${ca_r}"/></geometry>
      </collision>
      <inertial>
        <mass value="0.3"/>
        <inertia ixx="0.00015" ixy="0" ixz="0"
                 iyy="0.00015" iyz="0"
                 izz="0.00015"/>
      </inertial>
    </link>

    <joint name="${prefix}_caster_joint" type="continuous"> <!-- 修改：由 fixed 改为 continuous -->
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${reflect*ca_x} 0 ${ca_z}" rpy="0 0 0"/>
      <axis xyz="1 1 1"/> <!-- 全向自由旋转 -->
      <dynamics damping="0.0" friction="0.0"/>
    </joint>
  </xacro:macro>

  <xacro:caster prefix="front" reflect="1"/>
  <xacro:caster prefix="rear"  reflect="-1"/>

  <!-- ================== 激光雷达与摄像头 ================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
      <material name="red"/>
    </visual>
    <visual>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <geometry><cylinder radius="0.008" length="0.08"/></geometry>
      <material name="metal"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.04" length="0.07"/></geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.0003" ixy="0" ixz="0"
               iyy="0.0003" iyz="0"
               izz="0.0003"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.10 0 0.15" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00002" ixy="0" ixz="0"
               iyy="0.00002" iyz="0"
               izz="0.00002"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="lidar_link"/>
    <child link="camera_link"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
  </joint>

  <!-- ================== 深度相机光学坐标系 ================== -->
  <!-- Gazebo 深度相机插件使用光学坐标系（Z=光轴向前，X=右，Y=下），
       而 camera_link 的 Z 轴向上。添加 optical_frame 使 TF 自动处理旋转，
       避免点云出现在 camera_link 的正上方。 -->
  <link name="camera_depth_optical_frame">
    <inertial>
      <mass value="0.001"/>
      <inertia ixx="0.000001" ixy="0" ixz="0"
               iyy="0.000001" iyz="0"
               izz="0.000001"/>
    </inertial>
  </link>

  <joint name="camera_depth_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_depth_optical_frame"/>
    <!-- 旋转矩阵推导：
         camera_link: X=前, Y=左, Z=上
         optical:     X=右, Y=下, Z=前
         optical_X = -camera_Y, optical_Y = -camera_Z, optical_Z = camera_X
         对应 rpy = (-pi/2, 0, -pi/2) -->
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ================== Gazebo 插件与材质 ================== -->
  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <updateRate>100</updateRate>
      <leftJoint>left_wheel_joint</leftJoint>
      <rightJoint>right_wheel_joint</rightJoint>
      <wheelSeparation>0.68</wheelSeparation>
      <wheelDiameter>0.30</wheelDiameter>
      <wheelTorque>10</wheelTorque> 
      <commandTopic>cmd_vel</commandTopic>
      <odometryTopic>odom</odometryTopic> 
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_footprint</robotBaseFrame>
      <publishWheelTF>false</publishWheelTF>
      <publishWheelJointState>true</publishWheelJointState>
      <publishOdomTF>true</publishOdomTF>
      <odometrySource>world</odometrySource> <!-- 改回 world 以获得绝对平滑的转向里程计 -->
      <updateRate>50</updateRate>
    </plugin>
  </gazebo>

  <!-- ================== IMU 传感器 ================== -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>
      <topic>__default_topic__</topic>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <topicName>imu</topicName>
        <bodyName>imu_link</bodyName>
        <updateRateHZ>100.0</updateRateHZ>
        <gaussianNoise>0.005</gaussianNoise>
        <xyzOffset>0 0 0</xyzOffset>
        <rpyOffset>0 0 0</rpyOffset>
        <frameName>imu_link</frameName>
        <initialOrientationAsReference>false</initialOrientationAsReference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-2.356</min_angle> <!-- -135度，避开正后方的靠背 -->
            <max_angle>2.356</max_angle>  <!-- 135度 -->
          </horizontal>
        </scan>
        <range>
          <min>0.10</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="lidar_plugin" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>lidar_link</frameName>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================== RGB-D 深度摄像头（Kinect 风格） ================== -->
  <gazebo reference="camera_link">
    <sensor type="depth" name="camera_depth_sensor">
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      <camera name="camera">
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>10.0</far>
        </clip>
      </camera>
      <plugin name="camera_depth_plugin" filename="libgazebo_ros_openni_kinect.so">
        <baseline>0.1</baseline>
        <alwaysOn>true</alwaysOn>
        <updateRate>30</updateRate>
        <cameraName>camera</cameraName>
        <imageTopicName>rgb/image_raw</imageTopicName>
        <cameraInfoTopicName>rgb/camera_info</cameraInfoTopicName>
        <depthImageTopicName>depth/image_raw</depthImageTopicName>
        <depthImageCameraInfoTopicName>depth/camera_info</depthImageCameraInfoTopicName>
        <pointCloudTopicName>depth/points</pointCloudTopicName>
        <!-- 【修复】frameName 改为 optical_frame，使点云坐标系正确 -->
        <frameName>camera_depth_optical_frame</frameName>
        <distortionK1>0</distortionK1>
        <distortionK2>0</distortionK2>
        <distortionK3>0</distortionK3>
        <distortionT1>0</distortionT1>
        <distortionT2>0</distortionT2>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <mu1>0.3</mu1>
    <mu2>0.3</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="left_wheel_link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1000000.0</kp>
    <kd>1.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="front_caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <material>Gazebo/Grey</material>
  </gazebo>

</robot>
